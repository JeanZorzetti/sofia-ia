  id          String   @id @default(uuid()) @db.Uuid
  agentId     String   @map("agent_id") @db.Uuid
  mcpServerId String   @map("mcp_server_id") @db.Uuid
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  mcpServer McpServer @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)

  @@unique([agentId, mcpServerId])
  @@index([agentId])
  @@map("agent_mcp_servers")
}

// ─────────────────────────────────────────────────────────
// ThreadsScheduledPost — Fila de posts agendados para o Threads
// ─────────────────────────────────────────────────────────
model ThreadsScheduledPost {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  text        String    @db.Text
  scheduledAt DateTime  @map("scheduled_at") @db.Timestamptz()
  status      String    @default("pending") @db.VarChar(20)
  postId      String?   @map("post_id") @db.VarChar(255)
  createdBy   String?   @map("created_by") @db.VarChar(255)
  approvedBy  String?   @map("approved_by") @db.Uuid
  metadata    Json      @default("{}")
  publishedAt DateTime? @map("published_at") @db.Timestamptz()
  errorMsg    String?   @map("error_msg") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver User? @relation("ScheduledPostApprover", fields: [approvedBy], references: [id])

  campaignPost ThreadsCampaignPost?

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
  @@map("threads_scheduled_posts")
}

// ─────────────────────────────────────────────────────────
// ThreadsCampaign — Campanha de conteúdo estruturada
// ─────────────────────────────────────────────────────────
model ThreadsCampaign {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String   @db.VarChar(255)
  objective   String   @default("awareness") @db.VarChar(50)
  theme       String   @db.Text
  description String?  @db.Text
  status      String   @default("planning") @db.VarChar(20)
  startDate   DateTime @map("start_date") @db.Timestamptz()
  endDate     DateTime @map("end_date") @db.Timestamptz()
  metadata    Json     @default("{}")
  // Phase 1 (Teams subordination): a campaign is backed by a content Team. The
  // Team plans/writes the posts; "Planejar com IA" instantiates it and ingests
  // the run output into posts. SetNull so deleting the Team doesn't drop the campaign.
  teamId      String?  @map("team_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team  Team?                 @relation(fields: [teamId], references: [id], onDelete: SetNull)
  posts ThreadsCampaignPost[]

  @@index([userId])
  @@index([status])
  @@index([startDate])
  @@index([teamId])
  @@map("threads_campaigns")
}

// ─────────────────────────────────────────────────────────
// ThreadsCampaignPost — Post dentro de uma campanha
// ─────────────────────────────────────────────────────────
model ThreadsCampaignPost {
  id              String    @id @default(uuid()) @db.Uuid
  campaignId      String    @map("campaign_id") @db.Uuid
  scheduledPostId String?   @unique @map("scheduled_post_id") @db.Uuid
  position        Int       @default(0)
  tema            String    @db.Text
  angle           String?   @db.Text
  status          String    @default("draft") @db.VarChar(20)
  scheduledAt     DateTime? @map("scheduled_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  campaign      ThreadsCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  scheduledPost ThreadsScheduledPost? @relation(fields: [scheduledPostId], references: [id])

  @@index([campaignId])
  @@map("threads_campaign_posts")
}

// ─────────────────────────────────────────────────────────
// Polaris Teams — persistent multi-agent team (sub-project A)
// ─────────────────────────────────────────────────────────
model Team {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  config      Json     @default("{}")
  status      String   @default("active") @db.VarChar(20)
  createdBy   String   @map("created_by") @db.Uuid
  // 009-usecase-squads: null = Time avulso (legado byte-idêntico); setado = squad de uma empresa.
  // use case e squadKey vivem em config Json: { useCase?, squadKey? }
  companyId   String?  @map("company_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  creator  User         @relation(fields: [createdBy], references: [id])
  company  Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  members  TeamMember[]
  runs     TeamRun[]
  scheduledTeamRuns ScheduledTeamRun[]
  threadsCampaigns  ThreadsCampaign[]
  conversations     Conversation[]

  @@index([createdBy])
  @@index([status])
  @@index([companyId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  agentId   String   @map("agent_id") @db.Uuid
  role      String   @db.VarChar(20)
  model     String?  @db.VarChar(100)
  effort    String?  @db.VarChar(20)
  // Teams V2 (S1.1 — Tema A): per-member tool-capability policy (CapabilityPolicy).
  // Shape: { tools?, mcpAllowlist?, toolSkills?, filesystem? }. Null → legacy gate.
  capabilities Json?  @map("capabilities")
  // Teams V2.1 (S3.1 — Tema F1): per-member custom workflow instruction, concatenated
  // to the Agent's system prompt ONLY within this team. Null → only the Agent's own
  // prompt (byte-identical to legacy). Free-form text, no length cap (@db.Text).
  workflow  String?  @db.Text
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  assignedTasks  TeamTask[]
  messagesFrom   TeamMessage[] @relation("MessagesFrom")
  messagesTo     TeamMessage[] @relation("MessagesTo")
  memberUsages   TeamMemberUsage[]

  @@unique([teamId, agentId])
  @@index([teamId])
  @@index([agentId])
  @@map("team_members")
}

model TeamRun {
  id            String    @id @default(uuid()) @db.Uuid
  teamId        String    @map("team_id") @db.Uuid
  mission       String    @db.Text
  status        String    @default("pending") @db.VarChar(20)
  mode          String    @default("chat") @db.VarChar(20) // 'chat' | 'code' (Sub-projeto C)
  sandboxId     String?   @map("sandbox_id") @db.VarChar(255) // code-runs: the run's sandbox id
  // Git lifecycle (Sub-projeto C — C1): the worker clones repoUrl, works on `branch`,
  // and on success opens a PR (`prUrl`) against `baseBranch`. Token is never stored here.
  repoUrl       String?   @map("repo_url") @db.Text         // resolved repo (Team.config default or per-run override)
  baseBranch    String?   @map("base_branch") @db.VarChar(255) // PR target branch (default: main)
  branch        String?   @db.VarChar(255)                  // working branch: polaris/run-<id>
  gitMode       String?   @map("git_mode") @db.VarChar(20)  // S3.1: 'pr' (default/legado: branch + PR draft) | 'direct' (commit na base, sem PR). null = legado = 'pr'.
  commitSha     String?   @map("commit_sha") @db.VarChar(64)
  prUrl         String?   @map("pr_url") @db.Text
  prNumber      Int?      @map("pr_number")
  changedFiles  Json?     @map("changed_files")             // [{path,status}] from git diff --name-status
  outputDispatches Json? @map("output_dispatches")         // SP2: [{type,destination,status,error?,sentAt}]
  // Preview mode (Lovable-style): after a code-run completes, the worker keeps the
  // sandbox alive, starts the project's dev server, and exposes a public URL. Lifecycle
  // is driven off these fields (reaper/extend/stop reuse `sandboxId`). Inert otherwise.
  previewEnabled   Boolean   @default(false) @map("preview_enabled") // set from the mission composer toggle (code-runs only)
  previewStatus    String?   @map("preview_status") @db.VarChar(20)  // 'starting' | 'live' | 'failed' | 'stopped' | 'expired' | 'superseded' (a follow-up took over the sandbox)
  // Iteration (Lovable follow-ups): a continuation run reuses the parent's live sandbox +
  // branch + preview (commits the incremental diff). null = a fresh top-level run.
  parentRunId      String?   @map("parent_run_id") @db.Uuid
  previewUrl       String?   @map("preview_url") @db.Text            // public E2B host URL (https://{port}-{sandboxId}.e2b.app)
  previewPort      Int?      @map("preview_port")                    // dev server port exposed for the preview
  previewExpiresAt DateTime? @map("preview_expires_at") @db.Timestamptz() // when the reaper kills the sandbox
  previewError     String?   @map("preview_error") @db.Text          // failure reason when previewStatus='failed' (install/dev/static log tail)
  output        String?   @db.Text
  turnsUsed     Int?      @map("turns_used")
  tokensUsed    Int?      @map("tokens_used")
  estimatedCost Float?    @map("estimated_cost")
  durationMs    Int?      @map("duration_ms")
  error         String?   @db.Text
  // 008-team-run-resilience: quando status='rate_limited' por esgotamento do pool, o
  // horário (UTC) em que a janela reseta (parseResetAt, gravado por withRateLimitCapture).
  // null = reset desconhecido (o cron de auto-resume não o retoma). Indexado p/ a varredura.
  resetAt       DateTime? @map("reset_at") @db.Timestamptz()
  startedAt     DateTime  @default(now()) @map("started_at") @db.Timestamptz()
  completedAt   DateTime? @map("completed_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  team         Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks        TeamTask[]
  messages     TeamMessage[]
  memberUsages TeamMemberUsage[]

  @@index([teamId])
  @@index([status])
  @@index([status, resetAt]) // 008: cron resume-blocked-teams filtra rate_limited + resetAt<=now
  @@index([startedAt(sort: Desc)])
  @@index([parentRunId])
  @@map("team_runs")
}

model TeamTask {
  id         String   @id @default(uuid()) @db.Uuid
  runId      String   @map("run_id") @db.Uuid
  title      String   @db.VarChar(500)
  body       String?  @db.Text
  status     String   @default("todo") @db.VarChar(20)
  assigneeId String?  @map("assignee_id") @db.Uuid
  result     String?  @db.Text
  reviewNote String?  @map("review_note") @db.Text
  artifacts  Json?    // code-runs: { commands: [{cmd,stdout,stderr,exitCode,ms}] } (Sub-projeto C)
  historyEvents Json? @map("history_events") // V2.1 S2.1: append-only lifecycle timeline [{type,actor,at,detail?}]; NULL = legacy task (no events)
  dependsOn  String[] @default([]) @map("depends_on") // G1 (graph mode): TeamTask ids this task depends on; runTeamGraph gates execution on these
  related    String[] @default([]) @map("related") // V2.1 S3.2 (Tema F2): free cross-links (@TASK [related:#n]); DISPLAY/navigation only, never gates execution. `blocks` is DERIVED read-side (inverse of dependsOn) — no column.
  retryCount Int      @default(0) @map("retry_count")
  position   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  run      TeamRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  assignee TeamMember?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  messages TeamMessage[]

  @@index([runId])
  @@index([status])
  @@index([assigneeId]) // Sprint 2: tarefas por membro responsável
  @@map("team_tasks")
}

model TeamMessage {
  id           String   @id @default(uuid()) @db.Uuid
  runId        String   @map("run_id") @db.Uuid
  fromMemberId String?  @map("from_member_id") @db.Uuid
  toMemberId   String?  @map("to_member_id") @db.Uuid
  summary      String?  @db.Text
  content      String   @db.Text
  kind         String   @default("message") @db.VarChar(20)
  taskId       String?  @map("task_id") @db.Uuid
  // V2.2 S6: image/media attachments (vision). Array of { name, mime, size, key }
  // where `key` is the MinIO object key. Nullable → legacy rows untouched (text-only).
  attachments  Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  run        TeamRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  fromMember TeamMember? @relation("MessagesFrom", fields: [fromMemberId], references: [id], onDelete: SetNull)
  toMember   TeamMember? @relation("MessagesTo", fields: [toMemberId], references: [id], onDelete: SetNull)
  task       TeamTask?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([createdAt])
  @@map("team_messages")
}

// Teams V2 — S2.2: append-only per-call token attribution.
// One row per successful chat() call. Bounded by (turns × members). Agrega no read.
// FK de membro é SetNull (roster editado/deletado mid-run não derruba o run).
model TeamMemberUsage {
  id        String   @id @default(uuid()) @db.Uuid
  runId     String   @map("run_id") @db.Uuid
  memberId  String?  @map("member_id") @db.Uuid
  model     String?  @db.VarChar(100)
  tokens    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  run    TeamRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  member TeamMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([memberId])
  @@map("team_member_usage")
}

// =============================================================================
// 005-agentic-companies — Empresas Agênticas
// A camada de organização sobre os Agentes: organograma (CompanyRole), governança
// (RACI Json), processo (SDLC = constantes de código) e execução (CompanyRun →
// um TeamRun por fase via runTeamAndWait; coordinator INTOCADO).
// =============================================================================

// A Empresa: organização agêntica de primeira classe, instanciável por nicho.
// RACI + infra/SOPs como Json tipado (matriz pequena ~13×7; validação app-level).
model Company {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  niche       String   @db.VarChar(100) // chave do blueprint semente (ex.: software_house)
  typology    String   @default("hybrid") @db.VarChar(20) // generalist | specialist | hybrid
  description String?  @db.Text
  raci        Json     @default("{}") // { [phaseKey]: { [roleKey]: 'R'|'A'|'C'|'I' } } — validado por validateRaci
  config      Json     @default("{}") // { sops?: { [roleKey]: string }, infrastructure?: { [roleKey]: { sandbox?: boolean } } }
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  creator User          @relation(fields: [createdBy], references: [id])
  roles   CompanyRole[]
  runs    CompanyRun[]
  teams   Team[]

  @@index([createdBy])
  @@index([niche])
  @@map("companies")
}

// A vaga do organograma. Encaixe 1:1 via @unique em agentId (Postgres permite múltiplos NULL).
model CompanyRole {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  key        String   @db.VarChar(50) // chave estável p/ a RACI (ex.: backend)
  title      String   @db.VarChar(255)
  layer      String   @db.VarChar(20) // strategic | tactical | operational
  department String?  @db.VarChar(100)
  agentId    String?  @unique @map("agent_id") @db.Uuid // nullable = vaga vazia; @unique = 1:1 (FR-003a)
  position   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agent   Agent?  @relation(fields: [agentId], references: [id], onDelete: SetNull) // agente deletado → cargo volta a vago

  @@unique([companyId, key])
  @@index([companyId])
  @@map("company_roles")
}

// A execução da empresa (percorre as 7 fases do SDLC sequencialmente).
model CompanyRun {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  mission      String    @db.Text
  status       String    @default("pending") @db.VarChar(20) // pending | running | completed | failed | blocked
  currentPhase String?   @map("current_phase") @db.VarChar(30)
  output       String?   @db.Text
  error        String?   @db.Text
  // 007-company-run-resilience: quando status='blocked' por esgotamento do pool Claude,
  // o horário (UTC) em que a janela reseta (parseResetAt do output do CLI). null = reset
  // desconhecido (bloqueia, mas o cron de auto-resume não o retoma). Indexado p/ a varredura.
  resetAt      DateTime? @map("reset_at") @db.Timestamptz()
  createdBy    String    @map("created_by") @db.Uuid
  startedAt    DateTime? @map("started_at") @db.Timestamptz()
  completedAt  DateTime? @map("completed_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  phaseRuns CompanyPhaseRun[]

  @@index([companyId])
  @@index([status])
  @@index([status, resetAt]) // 007: cron resume-blocked-companies filtra blocked + resetAt<=now
  @@map("company_runs")
}

// Liga cada fase do SDLC ao TeamRun subjacente (criado via runTeamAndWait).
// teamRunId referencia TeamRun.id SEM FK formal (evita acoplar o schema de Times;
// o TeamRun é lido sob demanda). Times de fase nascem status:'internal' → fora da UI.
model CompanyPhaseRun {
  id             String    @id @default(uuid()) @db.Uuid
  companyRunId   String    @map("company_run_id") @db.Uuid
  phase          String    @db.VarChar(30) // key da fase do SDLC
  position       Int       @default(0) // ordem 0..6
  status         String    @default("pending") @db.VarChar(20) // pending | running | completed | failed | skipped | blocked
  teamRunId      String?   @map("team_run_id") @db.Uuid // o TeamRun real da fase (lookup read-side, sem FK)
  inputArtifact  String?   @map("input_artifact") @db.Text // saída da fase anterior (encadeamento N→N+1)
  outputArtifact String?   @map("output_artifact") @db.Text // resultado da fase (= TeamRun.output)
  error          String?   @db.Text
  // 007-company-run-resilience: proxy de consumo da fase, independente do token-count que
  // subconta o claude-cli. Shape: { turns, durationMs, byModel, weightedUnits, blocked }.
  usage          Json?
  startedAt      DateTime? @map("started_at") @db.Timestamptz()
  completedAt    DateTime? @map("completed_at") @db.Timestamptz()
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  companyRun CompanyRun @relation(fields: [companyRunId], references: [id], onDelete: Cascade)

  @@index([companyRunId])
  @@map("company_phase_runs")
}
