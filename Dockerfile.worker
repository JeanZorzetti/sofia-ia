# Dockerfile.worker — Polaris Teams · Code Factory worker (Sub-projeto C, C0)
# Runs the BullMQ worker that executes code-runs in E2B sandboxes.
# Deploy as a SEPARATE EasyPanel service from the same repo; NO HTTP port.
#
# Unlike the app image (Next standalone, which strips src/ + tsx), this keeps the
# full node_modules + src + tsx so `npm run worker` (tsx src/worker/index.ts) runs.

FROM node:20-alpine AS base
RUN apk add --no-cache libc6-compat openssl

# ── deps ──────────────────────────────────────────────────────────────────────
FROM base AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

# ── runner ────────────────────────────────────────────────────────────────────
FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# ── Claude Code CLI (subscription-billed agent models) ──────────────────────────
# code-runs whose member model is `claude-*` spawn this CLI on the worker host.
# Auth via CLAUDE_CODE_OAUTH_TOKEN env (set it on the EasyPanel worker service);
# do NOT set ANTHROPIC_API_KEY (that switches the CLI to pay-per-token billing).
#
# `bash` is REQUIRED for SANDBOX_PROVIDER=vps-local (003): VpsLocalProvider.exec runs
# `bash -lc <cmd>`, and alpine ships only busybox sh by default → without it the git
# clone fails with `spawn bash ENOENT` (exit 127). E2B's image already had bash.
RUN apk add --no-cache bash git ripgrep libstdc++ libgcc && \
    npm i -g @anthropic-ai/claude-code
ENV USE_BUILTIN_RIPGREP=0
ENV CLAUDE_CONFIG_DIR=/tmp/.claude
# The worker runs as root; allow --dangerously-skip-permissions in this container.
ENV IS_SANDBOX=1

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Generate the Prisma client into this image's node_modules.
RUN npx prisma generate

# Long-running background worker — no HTTP port to expose.
CMD ["npm", "run", "worker"]
