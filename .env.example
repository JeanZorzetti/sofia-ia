# ============================================
# Sofia — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha os valores

# ---- DATABASE ----
DATABASE_URL="postgresql://user:password@localhost:5432/sofia?schema=public"

# Pool de conexões (opcional)
# DB_POOL_SIZE=10
# DB_CONNECT_TIMEOUT=10000
# DB_POOL_TIMEOUT=30000
# DB_IDLE_TIMEOUT=30000

# ---- AUTENTICAÇÃO ----
JWT_SECRET="trocar-por-um-segredo-forte-em-producao"

# ---- AI PROVIDERS ----
# Groq — modelos: Llama 3.3 70B, DeepSeek R1 Distill, Qwen, Gemma, Mixtral
GROQ_API_KEY="gsk_..."

# OpenRouter — modelos: Claude, GPT, Gemini, DeepSeek V3/R1
OPENROUTER_API_KEY="sk-or-..."

# Embeddings (opcional — default: huggingface)
# EMBEDDING_PROVIDER="huggingface"  # ou "openai"
# HUGGINGFACE_API_KEY="hf_..."
# OPENAI_API_KEY="sk-..."

# ---- WHATSAPP (Evolution API) — LEGADO, removido na Fase 4 da migração WABA ----
EVOLUTION_API_URL="https://sua-instancia-evolution.com"
EVOLUTION_API_KEY="sua-chave-evolution"

# ---- WHATSAPP BUSINESS CLOUD API (WABA, oficial Meta) — multi-tenant ----
# Versão da Graph API (ex: v21.0)
WHATSAPP_API_VERSION="v21.0"
# App secret da Meta — valida a assinatura X-Hub-Signature-256 do webhook
META_APP_SECRET="seu-app-secret"
# Token de verificação do webhook (você define; mesmo valor no painel da Meta)
WHATSAPP_WEBHOOK_VERIFY_TOKEN="defina-um-token-forte"
# Chave de criptografia dos access tokens em repouso — `openssl rand -base64 32`
ENCRYPTION_KEY="base64-de-32-bytes"
# Embedded Signup (Fase 2) — App ID e config_id; expostos no client (público)
NEXT_PUBLIC_META_APP_ID="seu-app-id"
NEXT_PUBLIC_META_CONFIG_ID="seu-embedded-signup-config-id"
META_APP_ID="seu-app-id"
META_EMBEDDED_SIGNUP_CONFIG_ID="seu-embedded-signup-config-id"

# ---- CODE-RUN EXECUTOR (Teams code-mode / worker) ----
# Backend de execução dos code-runs. "e2b" (default) usa o E2B (sandbox remoto,
# teto de ~1h); "vps-local" usa o executor self-hosted no próprio worker (sem teto).
# SANDBOX_PROVIDER="e2b"
# Base dos diretórios de run quando SANDBOX_PROVIDER=vps-local. DEVE apontar para um
# VOLUME montado no container do worker (cada run vive em ${VPS_RUNS_DIR}/<id>/repo).
# VPS_RUNS_DIR="/runs"
# Concorrência de code-runs no worker (recomendado 1–2 na VPS compartilhada).
# CODE_RUN_CONCURRENCY="2"

# ---- CACHE (Redis) ----
# Opção 1: Redis local
# REDIS_URL="redis://localhost:6379"

# Opção 2: Upstash (serverless)
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# ---- APP ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ---- MONITORING (opcional) ----
# SENTRY_DSN="https://..."

# ---- CRON JOBS ----
# CRON_SECRET="trocar-em-producao"

# ---- THREADS (Meta) ----
THREADS_APP_ID="seu-app-id-threads"
THREADS_APP_SECRET="seu-app-secret-threads"

# ---- SIRIUS CRM (AgaaS Integration) ----
# API do Sirius CRM para tools dos agentes
SIRIUS_API_URL="https://sirius.roilabs.com.br"
SIRIUS_API_KEY="sua-api-key-do-sirius"

# Webhook verification (mesmo valor de SOFIA_WEBHOOK_SECRET no Sirius)
SIRIUS_WEBHOOK_SECRET="gerar-com-openssl-rand-base64-32"
